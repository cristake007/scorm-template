        "mode": "quiz"
      },
      "page": {
        "layout": {
          "maxWidth": "xl",
          "gap": "lg"
        },
        "blocks": [
          {
            "type": "text",
            "variant": "h1",
            "text": "Final checkpoint"
          },
          {
            "type": "text",
            "variant": "muted",
            "text": "Passing this quiz can be used for course success logic."
          },
          {
            "type": "layout.grid",
            "id": "l3-grid",
            "columns": {
              "sm": 1,
              "md": 2,
              "lg": 3
            },
            "gap": "lg",
            "items": [
              {
                "id": "l3-hero",
                "span": 2,
                "blocks": [
                  {
                    "type": "text",
                    "variant": "h2",
                    "text": "Big quiz card (span=2)"
                  },
                  {
                    "type": "quiz.mcq",
                    "quizId": "final-quiz",
