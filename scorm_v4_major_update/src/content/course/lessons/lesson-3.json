                    "scoreMax": 100,
                    "passScore": 80,
                    "attemptsAllowed": 0,
                    "shuffleOptions": true,
                    "questions": [
                      {
                        "id": "q1",
                        "prompt": "Which SCORM field stores the bookmark route?",
                        "options": [
                          {
                            "id": "a",
                            "text": "cmi.location"
                          },
                          {
                            "id": "b",
                            "text": "cmi.mode"
                          },
                          {
                            "id": "c",
                            "text": "cmi.progress_measure"
                          }
                        ],
                        "correct": [
                          "a"
                        ]
                      },
                      {
                        "id": "q2",
                        "prompt": "What field stores our progress JSON?",
                        "options": [
                          {
                            "id": "a",
                            "text": "cmi.suspend_data"
                          },
                          {
                            "id": "b",
                            "text": "cmi.exit"
                          },
                          {
                            "id": "c",
                            "text": "cmi.session_time"
                          }
                        ],
                        "correct": [
                          "a"
                        ]
                      }
                    ],
                    "onSubmit": {
                      "markChapterComplete": true,
                      "commit": true
                    }
                  }
                ]
              },
              {
                "id": "l3-side-a",
                "blocks": [
                  {
                    "type": "image",
                    "src": "./assets/images/final-a.jpg",
                    "alt": "Final A",
                    "ratio": "16/9",
                    "rounded": "lg"
                  },
                  {
                    "type": "text",
                    "variant": "muted",
                    "text": "Compact image card."
                  }
                ]
              },
              {
                "id": "l3-side-b",
                "blocks": [
                  {
                    "type": "section",
                    "id": "l3-sec",
                    "title": "Exit tip",
                    "variant": "card",
                    "padding": "lg",
                    "blocks": [
                      {
                        "type": "text",
                        "variant": "muted",
                        "text": "Use the Exit button to trigger terminate()."
                      }
                    ]
                  }
                ]
              }
            ]
          }
